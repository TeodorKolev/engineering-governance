# Engineering Governance Agent — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env with real secrets to version control.

# ─── Gemini API ───────────────────────────────────────────────────────────────
# Get a free key from https://aistudio.google.com/apikey (must start with AIza)
GEMINI_API_KEY=AIza_your_key_here
GOOGLE_GENAI_USE_VERTEXAI=false
GEMINI_MODEL=gemini-2.0-flash

# ─── GitHub MCP ───────────────────────────────────────────────────────────────
# Personal Access Token with: repo, read:org, read:packages
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# Optional: if using a hosted GitHub MCP SSE server instead of npx
# GITHUB_MCP_SSE_URL=https://your-github-mcp-server/sse

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Seconds to wait between sequential agents. Prevents 429 TPM bursts on the
# free tier. Set to 0 when using a paid API key or Vertex AI.
INTER_AGENT_DELAY_SECONDS=12
