# Engineering Governance Agent — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env with real secrets to version control.

# ─── Google Cloud ─────────────────────────────────────────────────────────────
# Set automatically from ADC (google.auth.default()) at runtime.
# Override here if needed:
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_GENAI_USE_VERTEXAI=True

# ─── GitHub MCP ───────────────────────────────────────────────────────────────
# Personal Access Token with: repo, read:org, read:packages
GITHUB_TOKEN=ghp_your_token_here

# Optional: if using a hosted GitHub MCP SSE server instead of npx
# GITHUB_MCP_SSE_URL=https://your-github-mcp-server/sse

# ─── Jira MCP ─────────────────────────────────────────────────────────────────
# Atlassian API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-org.atlassian.net
JIRA_USERNAME=your@email.com
JIRA_API_TOKEN=your_jira_api_token_here

# Optional: if using a hosted Jira MCP SSE server instead of npx
# JIRA_MCP_SSE_URL=https://your-jira-mcp-server/sse

# ─── AWS MCP ──────────────────────────────────────────────────────────────────
# For local dev: set access key + secret. For Cloud Run: use Workload Identity Federation.
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_PROFILE=default  # For local dev with ~/.aws/credentials

# Optional: if using a hosted AWS MCP SSE server instead of npx
# AWS_MCP_SSE_URL=https://your-aws-mcp-server/sse
